{
  "name": "@elastic/prismjs-esql",
  "version": "1.1.2",
  "publishConfig": {
    "access": "public"
  },
  "description": "Prism.js and Refractor ES|QL language syntax definitions for highlighting",
  "main": "lib/index.js",
  "files": [
    "NOTICE.txt",
    "LICENSE",
    "lib/"
  ],
  "scripts": {
    "format": "biome format ./src",
    "format:fix": "biome format --write ./src",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest ./src",
    "coverage": "vitest run --coverage",
    "clean": "npx rimraf@5.0.5 lib",
    "build:es2020": "tsc --project tsconfig.build.json",
    "build": "yarn build:es2020",
    "semantic-release:dry-run": "semantic-release --dry-run --debug",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elastic/prismjs-esql.git"
  },
  "keywords": [
    "esql",
    "prism",
    "prismjs",
    "refractor",
    "es|ql",
    "elastic",
    "spl"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/elastic/prismjs-esql/issues"
  },
  "homepage": "https://github.com/elastic/prismjs-esql#readme",
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/eslint-parser": "7.28.6",
    "@biomejs/biome": "2.4.10",
    "@eslint/js": "10.0.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@vitest/coverage-v8": "4.1.2",
    "eslint": "10.1.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "refractor": "5.0.0",
    "semantic-release": "25.0.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2",
    "vitest": "4.1.2"
  },
  "lint-staged": {
    "*.{js,ts,tsx,mjs}": [
      "eslint --fix"
    ]
  }
}
